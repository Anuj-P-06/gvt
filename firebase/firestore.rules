rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin checking function
    function isAdmin() {
      return request.auth != null;
    }
    
    // Products and Categories are readable by anyone, writable by admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Enquiries can be created by anyone, but only read/updated by admin
    match /enquiries/{enquiryId} {
      // Basic rate limiting/spam protection could be added here
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Analytics collections
    match /whatsapp_clicks/{clickId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Config read by anyone
    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
